{
  "feature_selection": {
    "correlation_threshold": 0.5,
    "method": "correlation"
  },
  "clustering": {
    "kmeans": {
      "max_k": 8,
      "random_state": 42,
      "elbow_method": true
    },
    "hdbscan": {
      "min_cluster_size": 2,
      "min_samples": 1,
      "cluster_selection_epsilon": 0.1
    },
    "target_weighting": {
      "enabled": false,
      "weight": 1.5
    }
  },
  "prediction": {
    "use_scaling": true,
    "scaler_type": "robust"
  },
  "overrides": {
    "apm_sd": {
      "kmeans_k": null,
      "hdbscan_min_cluster_size": null
    },
    "apm_smp": {
      "kmeans_k": null,
      "hdbscan_min_cluster_size": null
    },
    "apm_sm": {
      "kmeans_k": null,
      "hdbscan_min_cluster_size": null
    },
    "apk_pt": {
      "kmeans_k": null,
      "hdbscan_min_cluster_size": null
    },
    "rata_rata_lama_sekolah": {
      "kmeans_k": null,
      "hdbscan_min_cluster_size": null
    }
  }
}